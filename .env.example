OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat
OPENAI_BASE_URL=https://api.deepseek.com/v1

# MarketAgent provider: mock or deepseek
MARKET_AGENT_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30
CORS_ORIGINS=https://your-vercel-production-domain.vercel.app

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

ENABLE_EMAIL=false
# Defaults to the repository root and its reports/ directory when left empty.
WORKSPACE_ROOT=
REPORT_OUTPUT_DIR=reports
TIMEZONE=Asia/Shanghai
LOOKBACK_HOURS=24
FETCH_TIMEOUT_SECONDS=12
MARKET_DATA_TIMEOUT_SECONDS=12
IMAGE_DOWNLOAD_EVENT_LIMIT=24
IMAGE_DOWNLOAD_PER_EVENT=1
GOOGLE_NEWS_KEYWORDS=US stock market,S&P 500,Nasdaq,Dow Jones,Federal Reserve,US earnings,AI stocks,semiconductors,Mag 7 stocks,Tesla,Nvidia,Apple,Microsoft,Amazon,Meta,Google stock,bank stocks,energy stocks,retail earnings,small cap stocks,US Treasury yields,oil prices
